<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_with_logo"
    tools:context=".studentMainActivity2">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Profile Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/studentEmailHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="student@gmail.com"
                        android:textColor="@color/primary_blue"
                        android:textSize="14sp"
                        android:layout_marginBottom="2dp"/>

                    <TextView
                        android:id="@+id/studentDeviceIdText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Device ID: --"
                        android:textColor="#757575"
                        android:textSize="10sp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardCornerRadius="12dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#DDDDDD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">
                                <TextView
                                    android:id="@+id/studentNameText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="John Doe"
                                    android:textStyle="bold"
                                    android:textSize="18sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Active Student"
                                    android:textColor="@color/primary_blue"
                                    android:textSize="12sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <Button
                                android:id="@+id/btnMyCourses"
                                android:layout_width="100dp"
                                android:layout_height="36dp"
                                android:text="My Courses"
                                android:textSize="10sp"
                                android:padding="0dp"
                                android:layout_marginBottom="4dp"
                                android:backgroundTint="@color/primary_blue"
                                app:cornerRadius="8dp"/>
                            <Button
                                android:id="@+id/btnReports"
                                android:layout_width="100dp"
                                android:layout_height="36dp"
                                android:text="Reports"
                                android:textSize="10sp"
                                android:padding="0dp"
                                android:layout_marginBottom="4dp"
                                android:backgroundTint="@color/primary_blue"
                                app:cornerRadius="8dp"/>
                            <Button
                                android:id="@+id/btnLogout"
                                android:layout_width="100dp"
                                android:layout_height="36dp"
                                android:text="Logout"
                                android:textSize="10sp"
                                android:padding="0dp"
                                android:backgroundTint="@color/logout_red"
                                app:cornerRadius="8dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Session Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/circle_red"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Session"
                            android:textStyle="bold"
                            android:textColor="@color/primary_blue"
                            android:textSize="18sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: ACTIVE"
                        android:textColor="@color/status_green"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvActiveCourse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Course: --"
                        android:textSize="13sp"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:id="@+id/tvActiveVenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Venue: --"
                        android:textSize="13sp"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:id="@+id/tvExpectedGps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expected GPS: --"
                        android:textSize="13sp"
                        android:layout_marginBottom="2dp"/>

                    <TextView
                        android:id="@+id/tvCurrentGps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current GPS: --"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvSessionTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time: --"
                        android:textColor="@color/warning_orange"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvAttendanceStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendance: NOT MARKED"
                        android:textColor="@color/logout_red"
                        android:textSize="11sp"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnMarkAttendance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mark Attendance"
                        android:backgroundTint="@color/primary_blue"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Enroll in Course Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enroll in a New Course"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="Course Code/Name">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEnrollCourse"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnEnrollNow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enroll Now"
                        android:backgroundTint="@color/primary_blue"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- My Courses Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_course"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Course Icon"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Enrolled Courses"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/enrolledCoursesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
