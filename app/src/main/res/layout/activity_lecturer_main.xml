<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/lecturer_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_with_logo"
    tools:context=".LecturerMainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Profile Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/lecturerEmailHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="lec@gmail.com"
                        android:textColor="@color/primary_blue"
                        android:textSize="14sp"
                        android:layout_marginBottom="2dp"/>

                    <TextView
                        android:id="@+id/lecturerDeviceIdText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Device ID: --"
                        android:textColor="#757575"
                        android:textSize="10sp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardCornerRadius="12dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#DDDDDD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">
                                <TextView
                                    android:id="@+id/lecturerNameText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Active Lecturer"
                                    android:textStyle="bold"
                                    android:textSize="16sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <GridLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:layout_marginStart="12dp">

                            <Button
                                android:id="@+id/btnLecMyCourses"
                                android:layout_width="80dp"
                                android:layout_height="36dp"
                                android:text="My Courses"
                                android:textSize="8sp"
                                android:padding="0dp"
                                android:layout_margin="2dp"
                                android:backgroundTint="@color/primary_blue"
                                app:cornerRadius="8dp"/>
                            <Button
                                android:id="@+id/btnLecRedFlags"
                                android:layout_width="80dp"
                                android:layout_height="36dp"
                                android:text="Red Flags"
                                android:textSize="8sp"
                                android:padding="0dp"
                                android:layout_margin="2dp"
                                android:backgroundTint="@color/warning_orange"
                                app:cornerRadius="8dp"/>
                            <Button
                                android:id="@+id/btnLecReports"
                                android:layout_width="80dp"
                                android:layout_height="36dp"
                                android:text="Reports"
                                android:textSize="8sp"
                                android:padding="0dp"
                                android:layout_margin="2dp"
                                android:backgroundTint="@color/primary_blue"
                                app:cornerRadius="8dp"/>
                            <Button
                                android:id="@+id/btnLecLogout"
                                android:layout_width="80dp"
                                android:layout_height="36dp"
                                android:text="Logout"
                                android:textSize="8sp"
                                android:padding="0dp"
                                android:layout_margin="2dp"
                                android:backgroundTint="@color/logout_red"
                                app:cornerRadius="8dp"/>
                        </GridLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GPS Location Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Location (GPS)"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvLecCurrentLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fetching location..."
                        android:padding="12dp"
                        android:background="#EEEEEE"
                        android:textStyle="bold"
                        android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Add Course & Open Session Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_session"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="Session Icon"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Course &amp; Open Session"
                            android:textStyle="bold"
                            android:textColor="@color/primary_blue"
                            android:textSize="18sp"/>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="Course Name">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCourseName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="Venue">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVenueName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:id="@+id/tvSelectDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Select Date"
                            android:padding="12dp"
                            android:background="#EEEEEE"
                            android:layout_marginEnd="4dp"/>
                        <TextView
                            android:id="@+id/tvSelectTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Select Time"
                            android:padding="12dp"
                            android:background="#EEEEEE"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Venue GPS Coordinates"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <EditText
                            android:id="@+id/etLecLat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Latitude"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="14sp"/>
                        <EditText
                            android:id="@+id/etLecLon"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Longitude"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnAutoGps"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Capture Current GPS Automatically"
                        android:textColor="@color/primary_blue"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnOpenSession"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Open Session"
                        android:backgroundTint="@color/primary_blue"
                        app:cornerRadius="12dp"/>

                    <Button
                        android:id="@+id/btnEndSession"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="End Session"
                        android:backgroundTint="@color/logout_red"
                        android:visibility="gone"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- My Teaching Courses Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_course"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Course Icon"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Teaching Courses"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/teachingCoursesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"/>

            <!-- Your Open Sessions (Grid) Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_attendance"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Attendance Icon"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Currently Open Sessions"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Container for Sessions (Simulating a Grid) -->
            <LinearLayout
                android:id="@+id/sessionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
